#!/usr/bin/env ruby
# frozen_string_literal: true

# =============================================================================
# Script: load_data_dump
# =============================================================================
#
# Purpose:
#   Drops and recreates the database, then restores from the first .dump file
#   found in ~/Downloads using pg_restore.
#
# Usage:
#   ./bin/load_data_dump
#
# =============================================================================

# --- Find dump file ---

downloads_dir = File.expand_path("~/Downloads")
dump_file = Dir.glob(File.join(downloads_dir, "*.dump")).first

if dump_file.nil?
  puts "ERROR: No .dump files found in #{downloads_dir}. See https://neetozone.neetokb.com/articles/load-database-dump-locally and download the data dump."
  exit 1
end

puts "Using dump file: #{dump_file}"

DB_USER = "bigbinary"

# --- Ensure database user exists ---

system("createuser -s #{DB_USER} 2>/dev/null")

# --- Drop and recreate database ---

puts "Running db:drop db:create..."
unless system({ "DISABLE_DATABASE_ENVIRONMENT_CHECK" => "1" }, "bin/rails db:drop db:create")
  puts "ERROR: Failed to drop/create database"
  exit 1
end

# --- Determine database name ---

db_name = `bin/rails runner "puts ActiveRecord::Base.connection_db_config.configuration_hash[:database]" 2>/dev/null`.strip.lines.last&.strip

if db_name.nil? || db_name.empty?
  puts "ERROR: Could not determine database name"
  exit 1
end

puts "Database name: #{db_name}"

# --- Restore dump ---

cmd = "pg_restore --verbose --clean --no-acl --no-owner -h localhost -U #{DB_USER} -d #{db_name} #{dump_file}"
puts "Running: #{cmd}"
system(cmd)

puts ""
puts ""

# --- Fix environment metadata ---
# The production dump marks the DB as 'production' in ar_internal_metadata,
# which would block future destructive Rails commands. Reset it to development.

puts "Setting environment metadata to development and resetting all passwords to 'welcome'..."

require "tempfile"
script = Tempfile.new(["load_data_dump", ".rb"])
script.write(<<~RUBY)
  if ActiveRecord::Base.connection.table_exists?(:ar_internal_metadata)
    ActiveRecord::Base.connection.execute("UPDATE ar_internal_metadata SET value = 'development' WHERE key = 'environment'")
  end
  if ActiveRecord::Base.connection.table_exists?(:users)
    User.update_all(encrypted_password: Devise::Encryptor.digest(User, "welcome"))
  end
RUBY
script.close

system("mise exec -- bundle exec rails runner #{script.path}")
script.unlink

puts ""
puts "Done!!!"
