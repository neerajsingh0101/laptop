#!/usr/bin/env bash

if [[ ! -f .dev_launch ]]; then
  echo "Error: .dev_launch file not found in current directory"
  exit 1
fi

port=$(grep '^PORT_NUMBER=' .dev_launch | cut -d= -f2)

if [[ -z "$port" ]]; then
  echo "Error: PORT_NUMBER not found in .dev_launch"
  exit 1
fi

echo "tunnelto --subdomain spinkart --port $port"
tunnelto --subdomain spinkart --port "$port"
